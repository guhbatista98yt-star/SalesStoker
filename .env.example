DATABASE_URL=postgresql://postgres:senha@127.0.0.1:5435/database
PGSSLMODE=disable
PORT=9001
SESSION_SECRET=troque-por-um-segredo-longo-e-aleatorio
TOKEN_EXPIRY=30d

# Seeds automáticos devem ficar desligados em produção.
SEED_DEFAULT_USERS=false
# Se SEED_DEFAULT_USERS=true em produção, estas senhas são obrigatórias e devem ter 12+ caracteres.
DEFAULT_LOJA_PASSWORD=
DEFAULT_VENDOR_PASSWORD=

# Nunca habilite em produção sem decisão explícita.
ALLOW_DEMO_FINANCE_SEED=false
ALLOW_EMPTY_ERP_SNAPSHOT=false
ALLOW_LARGE_ERP_SNAPSHOT_DROP=false

# DB2 / ERP. Configure somente no ambiente que executa sincronização.
DB2_DSN=
DB2_UID=
DB2_PWD=
